{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "./src", 
    "types": ["jest"]
  },
  "files": [
    "src/main.ts",
    "src/main.server.ts",
    "src/server.ts",
    "src/app/app.config.ts",
    "src/app/app.config.server.ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}